---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="G-code Generator | Scorpio"
    description="Generate G-code from DXF files for your machine."
>
    <div class="max-w-4xl mx-auto py-8 px-4 space-y-8">
        <!-- Header -->
        <section class="text-center space-y-4">
            <h1 class="text-4xl font-black text-white tracking-tight">
                G-code <span class="text-emerald-500">Generator</span>
            </h1>
            <p class="text-slate-400 font-medium">
                Import DXF and generate machine-ready G-code.
            </p>
        </section>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Upload & Settings -->
            <div
                class="glass p-8 rounded-3xl border border-white/5 shadow-2xl space-y-6"
            >
                <div class="flex items-center justify-between">
                    <h2
                        class="text-xl font-bold text-white flex items-center gap-2"
                    >
                        <svg
                            class="w-5 h-5 text-emerald-400"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                            ></path>
                        </svg>
                        Import DXF
                    </h2>
                </div>

                <div class="relative group">
                    <input
                        type="file"
                        id="dxf-upload"
                        accept=".dxf"
                        class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white"
                    />
                    <label
                        for="dxf-upload"
                        class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-zinc-700 rounded-2xl cursor-pointer hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-all group"
                    >
                        <div
                            class="flex flex-col items-center justify-center pt-5 pb-6"
                        >
                            <svg
                                class="w-8 h-8 text-zinc-500 group-hover:text-emerald-400 transition-colors mb-2"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                                ></path>
                            </svg>
                            <p class="text-sm text-zinc-400" id="file-name">
                                Click to upload or drag and drop
                            </p>
                            <p class="text-xs text-zinc-600 mt-1">
                                DXF files only
                            </p>
                        </div>
                    </label>
                </div>

                <div class="grid grid-cols-2 gap-4 pt-4">
                    <div class="space-y-2">
                        <label class="text-xs font-mono text-zinc-500 uppercase"
                            >Feed Rate (F)</label
                        >
                        <input
                            type="number"
                            id="feed-rate"
                            value="5.0"
                            step="0.1"
                            class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white outline-none focus:border-emerald-500 transition-colors"
                        />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-mono text-zinc-500 uppercase"
                            >Spindle Speed (S)</label
                        >
                        <input
                            type="number"
                            id="spindle-speed"
                            value="3700"
                            class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white outline-none focus:border-emerald-500 transition-colors"
                        />
                    </div>
                </div>

                <button
                    id="generate-btn"
                    disabled
                    class="w-full bg-emerald-600 hover:bg-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold py-3 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2 group"
                >
                    Generate G-code
                </button>
            </div>

            <!-- Visual Representation -->
            <div id="visual-container" class="hidden space-y-6">
                <div
                    class="glass p-8 rounded-3xl border border-white/5 shadow-2xl h-full flex flex-col"
                >
                    <h2
                        class="text-xl font-bold text-white uppercase tracking-wider text-emerald-400 mb-4"
                    >
                        Visual Preview
                    </h2>
                    <div
                        class="flex-grow bg-zinc-950 rounded-2xl border border-zinc-800 relative min-h-[300px] flex items-center justify-center p-4 overflow-hidden"
                    >
                        <svg
                            id="dxf-svg"
                            class="w-full h-full max-h-[400px]"
                            preserveAspectRatio="xMidYMid meet"
                        >
                            <g id="svg-axes"></g>
                            <g id="svg-entities"></g>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Output -->
            <div id="output-container" class="hidden lg:col-span-2 space-y-6">
                <div
                    class="glass p-8 rounded-3xl border border-white/5 shadow-2xl"
                >
                    <div class="flex items-center justify-between mb-4">
                        <h2
                            class="text-xl font-bold text-white uppercase tracking-wider text-emerald-400"
                        >
                            Generated G-code
                        </h2>
                        <button
                            id="download-btn"
                            class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 text-white rounded-lg text-sm font-bold flex items-center gap-2 transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path>
                            </svg>
                            Download .txt
                        </button>
                    </div>
                    <div class="relative">
                        <pre
                            id="gcode-preview"
                            class="bg-zinc-950 p-6 rounded-2xl border border-zinc-800 font-mono text-sm overflow-x-auto max-h-[500px]">
                        </pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { DxfParser } from "dxf-parser";

    const dxfUpload = document.getElementById("dxf-upload") as HTMLInputElement;
    const fileName = document.getElementById("file-name");
    const generateBtn = document.getElementById(
        "generate-btn",
    ) as HTMLButtonElement;
    const outputContainer = document.getElementById("output-container");
    const visualContainer = document.getElementById("visual-container");
    const svgEntities = document.getElementById("svg-entities");
    const svgAxes = document.getElementById("svg-axes");
    const dxfSvg = document.getElementById(
        "dxf-svg",
    ) as unknown as SVGSVGElement;
    const gcodePreview = document.getElementById("gcode-preview");
    const downloadBtn = document.getElementById("download-btn");
    const feedRateInput = document.getElementById(
        "feed-rate",
    ) as HTMLInputElement;
    const spindleSpeedInput = document.getElementById(
        "spindle-speed",
    ) as HTMLInputElement;

    let dxfContent: string | null = null;
    let generatedGcodeParts: { text: string; color?: string }[] = [];

    const COLORS = [
        "#f87171",
        "#fb923c",
        "#fbbf24",
        "#a3e635",
        "#34d399",
        "#22d3ee",
        "#60a5fa",
        "#818cf8",
        "#a78bfa",
        "#f472b6",
    ];

    dxfUpload?.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) {
            if (fileName) fileName.textContent = file.name;
            const reader = new FileReader();
            reader.onload = (event) => {
                dxfContent = event.target?.result as string;
                generateBtn.disabled = false;
                processDxf(); // Auto-preview on upload
            };
            reader.readAsText(file);
        }
    });

    generateBtn?.addEventListener("click", () => {
        processDxf();
    });

    function processDxf() {
        if (!dxfContent) return;

        try {
            const parser = new DxfParser();
            const dxf = parser.parseSync(dxfContent.trim());
            const feedRate = feedRateInput.value || "5.0";
            const spindleSpeed = spindleSpeedInput.value || "3700";

            const result = generateGcode(dxf, feedRate, spindleSpeed);
            generatedGcodeParts = result.parts;

            renderPreview(generatedGcodeParts);
            renderVisual(result.entities);

            outputContainer?.classList.remove("hidden");
            visualContainer?.classList.remove("hidden");
        } catch (err: any) {
            console.error("DXF Parse Error:", err);
            alert(`Error parsing DXF file: ${err.message || err}`);
        }
    }

    function renderPreview(parts: { text: string; color?: string }[]) {
        if (!gcodePreview) return;
        gcodePreview.innerHTML = "";
        parts.forEach((part) => {
            const span = document.createElement("span");
            span.textContent = part.text + "\n";
            if (part.color) span.style.color = part.color;
            else span.style.color = "#10b981"; // Default emerald
            gcodePreview.appendChild(span);
        });
    }

    function renderVisual(entities: any[]) {
        if (!svgEntities || !svgAxes || !dxfSvg) return;
        svgEntities.innerHTML = "";
        svgAxes.innerHTML = "";

        let minX = Infinity,
            minY = Infinity,
            maxX = -Infinity,
            maxY = -Infinity;

        entities.forEach((item, index) => {
            const e = item.entity;
            const color = item.color;
            const pts = getEndpoints(e)!;

            const drawPath = (d: string) => {
                const path = document.createElementNS(
                    "http://www.w3.org/2000/svg",
                    "path",
                );
                path.setAttribute("d", d);
                path.setAttribute("stroke", color);
                path.setAttribute("stroke-width", "0.15");
                path.setAttribute("fill", "none");
                path.setAttribute("stroke-linecap", "round");
                svgEntities.appendChild(path);
            };

            if (e.type === "LINE") {
                const x1 = pts.start.x;
                const y1 = -pts.start.y;
                const x2 = pts.end.x;
                const y2 = -pts.end.y;
                drawPath(`M ${x1} ${y1} L ${x2} ${y2}`);

                minX = Math.min(minX, x1, x2);
                maxX = Math.max(maxX, x1, x2);
                minY = Math.min(minY, y1, y2);
                maxY = Math.max(maxY, y1, y2);
            } else if (e.type === "ARC") {
                const cx = e.center.x;
                const cy = -e.center.y;
                const r = e.radius;

                const startX = e.center.x + r * Math.cos(e.startAngle);
                const startY = -(e.center.y + r * Math.sin(e.startAngle));
                const endX = e.center.x + r * Math.cos(e.endAngle);
                const endY = -(e.center.y + r * Math.sin(e.endAngle));

                const largeArcFlag =
                    Math.abs(e.endAngle - e.startAngle) > Math.PI ? 1 : 0;
                const sweepFlag = 0; // Changed to 0 as it was "opposite"

                drawPath(
                    `M ${startX} ${startY} A ${r} ${r} 0 ${largeArcFlag} ${sweepFlag} ${endX} ${endY}`,
                );

                minX = Math.min(minX, startX, endX, cx - r);
                maxX = Math.max(maxX, startX, endX, cx + r);
                minY = Math.min(minY, startY, endY, cy - r);
                maxY = Math.max(maxY, startY, endY, cy + r);
            }
        });

        // Add axes
        minX = Math.min(minX, 0);
        maxX = Math.max(maxX, 0);
        minY = Math.min(minY, 0);
        maxY = Math.max(maxY, 0);

        const padding = 5;
        const width = maxX - minX || 10;
        const height = maxY - minY || 10;

        const drawAxis = (x1: number, y1: number, x2: number, y2: number) => {
            const line = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "line",
            );
            line.setAttribute("x1", x1.toString());
            line.setAttribute("y1", y1.toString());
            line.setAttribute("x2", x2.toString());
            line.setAttribute("y2", y2.toString());
            line.setAttribute("stroke", "#3f3f46"); // zinc-700
            line.setAttribute("stroke-width", "0.05");
            line.setAttribute("stroke-dasharray", "0.5,0.5");
            svgAxes.appendChild(line);
        };

        // X-axis
        drawAxis(minX - padding, 0, maxX + padding, 0);
        // Y-axis
        drawAxis(0, minY - padding, 0, maxY + padding);

        dxfSvg.setAttribute(
            "viewBox",
            `${minX - padding} ${minY - padding} ${width + padding * 2} ${height + padding * 2}`,
        );
    }

    downloadBtn?.addEventListener("click", () => {
        const text = generatedGcodeParts.map((p) => p.text).join("\n");
        const blob = new Blob([text], { type: "text/plain" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "generated_gcode.txt";
        a.click();
        URL.revokeObjectURL(url);
    });

    function getEndpoints(entity: any) {
        if (entity.type === "LINE") {
            return {
                start: { x: entity.vertices[0].x, y: entity.vertices[0].y },
                end: { x: entity.vertices[1].x, y: entity.vertices[1].y },
            };
        } else if (entity.type === "ARC") {
            const cx = entity.center.x || 0;
            const cy = entity.center.y || 0;
            const r = entity.radius;
            const startAngle = entity.startAngle;
            const endAngle = entity.endAngle;
            return {
                start: {
                    x: cx + r * Math.cos(startAngle),
                    y: cy + r * Math.sin(startAngle),
                },
                end: {
                    x: cx + r * Math.cos(endAngle),
                    y: cy + r * Math.sin(endAngle),
                },
            };
        }
        return null;
    }

    function generateGcode(dxf: any, feed: string, spindle: string) {
        let parts: { text: string; color?: string }[] = [];

        parts.push({ text: "00060 (AE25059) ;" });
        parts.push({ text: "M01 ;" });
        parts.push({ text: "" });
        parts.push({ text: "G98 G28 Y0 ;" });
        parts.push({ text: "G28 X0 ;" });
        parts.push({ text: "" });
        parts.push({ text: `M03 S${spindle} ;` });
        parts.push({ text: "" });
        parts.push({ text: "(POZYCJA STARTOWA - taka sama jak w bazowym)" });
        parts.push({ text: "G90 G01 X[111.285-05] F500 ;" });
        parts.push({ text: "G90 G01 Y[-93.460+0.5] F500 ;" });
        parts.push({ text: "" });
        parts.push({ text: "(START PROFILU)" });
        parts.push({ text: "G91 ;" });

        const originalEntities = dxf.entities.filter((e: any) =>
            ["LINE", "ARC"].includes(e.type),
        );

        if (originalEntities.length === 0)
            return { parts, entities: [], origin: { x: 0, y: 0 } };

        // Chaining algorithm
        const chained: any[] = [];
        const remaining = [...originalEntities];
        let first = remaining.shift();
        let endpoints = getEndpoints(first);
        const originX = endpoints!.start.x;
        const originY = endpoints!.start.y;

        chained.push({
            entity: first,
            reversed: false,
            color: COLORS[0 % COLORS.length],
        });
        let currentPos = endpoints!.end;

        while (remaining.length > 0) {
            let found = false;
            for (let i = 0; i < remaining.length; i++) {
                const e = remaining[i];
                const pts = getEndpoints(e);
                if (!pts) continue;

                if (
                    Math.hypot(
                        pts.start.x - currentPos.x,
                        pts.start.y - currentPos.y,
                    ) < 0.05
                ) {
                    chained.push({
                        entity: e,
                        reversed: false,
                        color: COLORS[chained.length % COLORS.length],
                    });
                    currentPos = pts.end;
                    remaining.splice(i, 1);
                    found = true;
                    break;
                }
                if (
                    Math.hypot(
                        pts.end.x - currentPos.x,
                        pts.end.y - currentPos.y,
                    ) < 0.05
                ) {
                    chained.push({
                        entity: e,
                        reversed: true,
                        color: COLORS[chained.length % COLORS.length],
                    });
                    currentPos = pts.start;
                    remaining.splice(i, 1);
                    found = true;
                    break;
                }
            }
            if (!found) break;
        }

        let toolX = originX;
        let toolY = originY;

        chained.forEach((item, idx) => {
            const e = item.entity;
            const rev = item.reversed;
            const color = item.color;
            const pts = getEndpoints(e)!;
            const end = rev ? pts.start : pts.end;

            const dx = end.x - toolX;
            const dy = end.y - toolY;

            const label = `(P${idx + 1} -> P${idx + 2} ${e.type === "LINE" ? "linia" : "łuk"})`;
            parts.push({ text: label, color: color });

            if (e.type === "LINE") {
                parts.push({
                    text: `G01 X${dx.toFixed(3)} Y${dy.toFixed(3)} F${feed} ;`,
                    color: color,
                });
            } else if (e.type === "ARC") {
                const r = e.radius;
                const cmd = rev ? "G02" : "G03";
                parts.push({
                    text: `${cmd} X${dx.toFixed(3)} Y${dy.toFixed(3)} R${r.toFixed(3)} F${feed} ;`,
                    color: color,
                });
            }
            parts.push({ text: "" });
            toolX = end.x;
            toolY = end.y;
        });

        parts.push({ text: "M05 ;" });
        parts.push({ text: "" });
        parts.push({ text: "G91 G28 Y0 ;" });
        parts.push({ text: "G91 G28 X0 ;" });
        parts.push({ text: "" });
        parts.push({ text: "M30 ;" });

        return { parts, entities: chained, origin: { x: originX, y: originY } };
    }
</script>

<style>
    .glass {
        background: rgba(10, 10, 12, 0.7);
        backdrop-filter: blur(12px);
    }
</style>
